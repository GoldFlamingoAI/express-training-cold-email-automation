# This project is Google Apps Script (cloud-only). There is no local build,
# no package manager, and no compiled output — so this file is deliberately lean.
# Secrets live in Apps Script PropertiesService, never in the repo.

# ── Secrets / environment (belt-and-suspenders — none of these are used) ─
.env
.env.local
.env.*.local

# ── OS noise ─────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Temporary ────────────────────────────────────────────────────────
*.tmp
*.temp
*.log
