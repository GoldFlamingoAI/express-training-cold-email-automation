# Script properties for the warm-up Apps Script project (File > Project Settings > Script Properties).
# Never commit real values. All Gmail access uses per-account OAuth refresh tokens over
# UrlFetchApp — this project has NO Gmail OAuth scope of its own.

WARMUP_SHEET_ID=<warm-up spreadsheet ID>
WARMUP_FROM_EMAIL=<mailbox on the outreach domain, e.g. adam@example-outreach.com>
WARMUP_START_DATE=<ISO date the manual layer begins, e.g. 2026-07-28>

HOSTINGER_API_TOKEN=<bearer token from Hostinger Panel -> Emails -> API>
# Optional overrides — verify the send path against https://api.mail.hostinger.com/ docs:
# HOSTINGER_API_BASE_URL=https://api.mail.hostinger.com
# HOSTINGER_SEND_ENDPOINT=<full URL if the documented send path differs>

# Optional documentation-only labels. The code does not read these two properties.
OAUTH_PROJECT_OWNER_EMAIL=<exact Gmail account that owns the warmup-infra Cloud project>
OAUTH_CLOUD_PROJECT_ID=<exact Google Cloud project ID, not only its display name>

# Required exact property names. SeedAccountService.gs reads these names literally.
OAUTH_CLIENT_ID=<from the warm-up Google Cloud project>
OAUTH_CLIENT_SECRET=<from the warm-up Google Cloud project>

# One refresh token per confirmed seed Gmail. The actual token is the Script Property value;
# only each property name goes in that Gmail's SEED_ACCOUNTS.tokenPropertyKey cell.
SEED_TOKEN_GFAIS=<refresh token authorized as gfais.demo@gmail.com>
SEED_TOKEN_ADAMAGDEV_DATA=<refresh token authorized as adamagdev.data@gmail.com>
SEED_TOKEN_GOLDFLAMINGO_ARTI=<refresh token authorized as goldflamingo.arti@gmail.com>
SEED_TOKEN_KITKATM_0208=<refresh token authorized as kitkatm.0208@gmail.com>

GEMINI_API_KEY=<Google AI Studio key; optional — local templates are the fallback>

# Optional ramp overrides (defaults: 2/day -> 3/day over 21 days):
# WARMUP_START_PER_DAY=2
# WARMUP_MAX_PER_DAY=3
# WARMUP_RAMP_DAYS=21
